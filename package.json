{
  "name": "tomxtractor-49ja",
  "version": "1.0.3",
  "description": "TomXtractor 49ja v1.0 - Professional Email Extraction Tool",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "wait-on http://localhost:5173 && tsc -p tsconfig.main.json && electron .",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "build:admin:renderer": "vite build -c admin-vite.config.ts",
    "build:admin:main": "tsc -p tsconfig.admin.json",
    "build:admin": "npm run build:admin:renderer && npm run build:admin:main",
    "package": "npm run build && electron-builder --win",
    "package:admin": "npm run build:admin && electron-builder --win --config admin-builder.json",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "chromium": "^3.0.3",
    "crypto-js": "^4.2.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "fast-csv": "^5.0.2",
    "firebase": "^12.11.0",
    "nodemailer": "^8.0.2",
    "pdf-parse": "^2.4.5",
    "puppeteer-core": "^23.8.0",
    "sql.js": "^1.11.0",
    "systeminformation": "^5.23.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.460.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.tomxtractor.49ja",
    "productName": "TomXtractor 49ja",
    "publish": [
      {
        "provider": "github",
        "owner": "markped1",
        "repo": "tomxtract"
      }
    ],
    "files": [
      "dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "publisherName": "TomXtractor"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/sql.js/**",
      "node_modules/chromium/**"
    ]
  }
}
