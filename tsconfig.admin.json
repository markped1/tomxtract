{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist/admin",
    "rootDir": "src/admin"
  },
  "include": ["src/admin/main.ts", "src/admin/admin-preload.ts"]
}
